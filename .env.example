# ─── Twilio (outbound calls + SMS + voice webhooks) ──────────────────────────
# The dialer authenticates with ACCOUNT_SID + AUTH_TOKEN (api/_lib/twilio.js).
# API Key auth does NOT work for this account, so AUTH_TOKEN is REQUIRED.
# AUTH_TOKEN is also what verifies inbound Twilio webhook signatures.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
# Optional country-specific outbound caller IDs (getFromNumber picks by prefix):
# TWILIO_UK_NUMBER=+44xxxxxxxxxx
# TWILIO_AU_NUMBER=+61xxxxxxxxx
# Where the power dialer rings YOU first before bridging to the lead
# (point this at the caller's phone, not necessarily Godwin's):
FORWARD_TO_MOBILE=+91xxxxxxxxxx
# ── Softphone / power dialer (Twilio Voice SDK) ──────────────────────────────
# Required for the in-browser softphone (headset dialing, auto-dial, voicemail
# drop). Create a Standard API Key in the Twilio console, and a TwiML App whose
# Voice Request URL points to https://vyrrahlabs.com/api/voice/outbound (POST).
# Without these the dialer falls back to phone-bridge mode automatically.
# TWILIO_API_KEY=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_TWIML_APP_SID=APxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pre-recorded voicemail-drop audio (public MP3/WAV). If unset, a TTS line plays.
# VOICEMAIL_URL=https://vyrrahlabs.com/vm.mp3
# Set to 'off' to disable call recording (2-party-consent states). Default: on.
# CALL_RECORDING=on
# Base URL for Twilio callbacks (defaults to https://vyrrahlabs.com):
# PUBLIC_BASE=https://vyrrahlabs.com

# Set to 1 to REJECT inbound Twilio webhooks with a bad/missing signature (403).
# Unset/0 = warn-and-continue (current default). Turn on once webhook URLs are live.
STRICT_TWILIO=0

# ─── Supabase (leads, calls, sms, sequences, opt_outs) ───────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Backend prefers the SERVICE_ROLE key; ANON works but is more restricted.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Admin auth (dialer panel) ───────────────────────────────────────────────
# JWT_SECRET signs the admin login token. REQUIRED for the login flow.
JWT_SECRET=your-32-char-random-secret-here!!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
# IMPORTANT: until ADMIN_KEY is set, the API falls OPEN (every endpoint is
# callable without auth, incl. /api/calls/dial and /api/sms/send). SET THIS
# before go-live. With it set, the JWT login still works; non-JWT calls need
# this key as `x-admin-key` header, `?admin_key=`, or Bearer token.
ADMIN_KEY=another-long-random-string

# ─── Email (optional — warm follow-up sequences via SendGrid) ────────────────
# SENDGRID_API_KEY=SG.xxxxxxxx
# SENDGRID_FROM_EMAIL=godwin@vyrrahlabs.com
# SENDGRID_FROM_NAME=Godwin Rayen
