{
  "version": 2,
  "routes": [
    {
      "src": "/admin",
      "dest": "/admin.html"
    },
    {
      "src": "/audit",
      "dest": "/audit.html"
    },
    {
      "src": "/results",
      "dest": "/results.html"
    },
    {
      "src": "/recaller",
      "dest": "/recover.html"
    },
    {
      "src": "/recover",
      "dest": "/recover.html"
    },
    {
      "src": "/start",
      "dest": "/start.html"
    },
    {
      "src": "/command",
      "dest": "/command.html"
    },
    {
      "src": "/api/analyze",
      "dest": "/api/analyze"
    },
    {
      "src": "/api/tool/(.*)",
      "dest": "/api/tool?path=$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index?path=$1"
    }
  ],
  "crons": [
    {
      "path": "/api/sequences/process",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/tool/cron-weekly",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/tool/cron-flush",
      "schedule": "0 13 * * *"
    }
  ]
}